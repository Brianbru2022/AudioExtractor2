{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audio Extractor 2",
  "version": "0.1.0",
  "identifier": "com.openai.audioextractor2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Audio Extractor 2",
        "width": 1560,
        "height": 980,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
